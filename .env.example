# Taste engine (Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Cursor-backed redesign drafts (optional; deterministic fallback works without it)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_AGENT_TIMEOUT_MS=75000

# Reserved for richer source-aware diffs (optional)
ANTHROPIC_API_KEY=

# Fixture URLs for local demo
TELL_FIXTURE_URL=http://localhost:3001
TELL_REPORT_ARTIFACT=fixtures/reports/tell-report.json

# Deployment (production)
TELL_DISABLE_REPO_SETUP=1
TELL_REPO_ROOT=
TELL_CAPTURE_TIMEOUT_MS=60000

# Hybrid: Vercel UI → Render capture backend (set on Vercel after Render deploy)
# Example: https://tell-capture.onrender.com
TELL_CAPTURE_API_URL=
